+/**
+ * Streams Claude with automatic continuation when the provider stops at max_tokens.
+ * @param {import('node-fetch').Response} initialResponse Initial Claude response
+ * @param {express.Response} response Express response
+ * @param {object} requestBody Claude request body
+ * @param {string} apiUrl Claude API base URL
+ * @param {string} apiKey Claude API key

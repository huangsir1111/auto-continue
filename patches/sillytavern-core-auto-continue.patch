+/**
+ * Forwards one Claude streaming response while collecting text and stop metadata.
+ * @param {import('node-fetch').Response} fetchResponse Fetch response from Claude
+ * @param {express.Response} response Express response
+ * @param {{finalPass: boolean, endMarker: string, assistantText: string}} options Stream options
+ * @returns {Promise<{assistantText: string, stopReason: string, endMarkerFound: boolean}>}
+ */
+async function forwardClaudeAutoContinueStream(fetchResponse, response, options) {
+    if (!fetchResponse.ok) {
+        const rawErrorText = await fetchResponse.text();
+        const detail = rawErrorText || 'Unknown error occurred';
+        console.warn(`Claude auto-continue streaming request failed with status ${fetchResponse.status} ${fetchResponse.statusText}: ${detail}`);
+
+        if (!response.headersSent) {
+            response.statusCode = fetchResponse.status === 401 ? 400 : fetchResponse.status;
+            response.statusMessage = fetchResponse.statusText;
+        }
+
+        response.end(rawErrorText, 'utf-8');
+        return {
+            assistantText: options.assistantText,
+            stopReason: '',
+            endMarkerFound: false,
+        };
+    }
+
+    if (!response.headersSent) {
+        response.statusCode = fetchResponse.status;
+        response.statusMessage = fetchResponse.statusText;
+        response.setHeader('Content-Type', fetchResponse.headers.get('content-type') || 'text/event-stream');
+        response.setHeader('Cache-Control', 'no-cache');
+        response.setHeader('Connection', 'keep-alive');
+    }
+
+    const decoder = new util.TextDecoder();
+    let buffer = '';
+    let assistantText = options.assistantText;
+    let stopReason = '';
+    let endMarkerFound = hasClaudeAutoContinueEndMarker(assistantText, options.endMarker);
+
+    const processBlock = (block) => {
+        if (!block.trim()) {
+            return;
+        }
+
+        const parsed = parseSseBlock(block);
+        const isDone = parsed.data.trim() === '[DONE]';
+
+        if (isDone) {
+            if (options.finalPass) {
+                writeSseBlock(response, block);
+            }
+            return;
+        }
+
+        const json = tryParse(parsed.data);
+        if (!json) {
+            if (!endMarkerFound) {
+                writeSseBlock(response, block);
+            }
+            return;
+        }
+
+        const textDelta = json?.type === 'content_block_delta' && typeof json?.delta?.text === 'string'
+            ? json.delta.text
+            : '';
+
+        if (textDelta) {
+            if (endMarkerFound) {
+                return;
+            }
+
+            const trimmedDelta = trimClaudeAutoContinueDeltaAtEndMarker(assistantText, textDelta, options.endMarker);
+            assistantText += trimmedDelta.text;
+            endMarkerFound = trimmedDelta.found || hasClaudeAutoContinueEndMarker(assistantText, options.endMarker);
+
+            if (!trimmedDelta.text) {
+                return;
+            }
+
+            if (trimmedDelta.text !== textDelta) {
+                const sanitizedJson = structuredClone(json);
+                sanitizedJson.delta.text = trimmedDelta.text;
+                writeSseBlock(response, block.replace(parsed.data, JSON.stringify(sanitizedJson)));
+                return;
+            }
+        }
+
+        if (json?.type === 'message_delta' && typeof json?.delta?.stop_reason === 'string') {
+            stopReason = json.delta.stop_reason;
+        }
+
+        if (!endMarkerFound) {
+            writeSseBlock(response, block);
+        } else if (textDelta) {
+            writeSseBlock(response, block);
+        }
+    };
+
+    if (fetchResponse.body) {
+        for await (const chunk of fetchResponse.body) {
+            buffer += decoder.decode(chunk, { stream: true });
+
+            while (true) {
+                const separator = findSseSeparator(buffer);
+                if (!separator) {
+                    break;
+                }
+
+                const block = buffer.slice(0, separator.index);
+                buffer = buffer.slice(separator.index + separator.length);
+                processBlock(block);
+            }
+        }
+    }
+
+    buffer += decoder.decode();
+    if (buffer.trim()) {
+        processBlock(buffer);
+    }
+
+    return { assistantText, stopReason, endMarkerFound };
+}

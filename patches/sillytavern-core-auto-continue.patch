+
+        if (!shouldContinue) {
+            if (!response.destroyed) {
+                response.end();
+            }
+            return;
+        }
+
+        const continuationBody = structuredClone(requestBody);
+        continuationBody.messages = createClaudeContinuationMessages(requestBody.messages, assistantText, options.continuationPrompt, options.endMarker);
+
+        writeClaudeAutoContinueStatus(response, callIndex + 2, options.maxCalls);
+        console.debug(`Claude auto-continue pass ${callIndex + 2}/${options.maxCalls}:`, continuationBody);

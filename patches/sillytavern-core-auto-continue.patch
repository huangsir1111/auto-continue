+        fetchResponse = await fetch(apiUrl + '/messages', {
+            method: 'POST',
+            signal,
+            body: JSON.stringify(continuationBody),
+            headers: {
+                'Content-Type': 'application/json',
+                'anthropic-version': '2023-06-01',
+                'x-api-key': apiKey,
+                ...additionalHeaders,
+            },
+        });
+    }
+
+    if (!response.destroyed) {
+        response.end();
+    }

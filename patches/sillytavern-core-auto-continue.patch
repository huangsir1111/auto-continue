+ * @param {AbortSignal} signal Abort signal
+ * @param {{enabled: boolean, endMarker: string, maxCalls: number, continuationPrompt: string, continueTrigger: string}} options Auto-continue options
+ * @returns {Promise<void>}
+ */
+async function streamClaudeWithAutoContinue(initialResponse, response, requestBody, apiUrl, apiKey, additionalHeaders, signal, options) {
+    let fetchResponse = initialResponse;
+    let assistantText = '';
+
+    for (let callIndex = 0; callIndex < options.maxCalls; callIndex++) {
+        const finalPass = callIndex === options.maxCalls - 1;
+        const result = await forwardClaudeAutoContinueStream(fetchResponse, response, {
+            finalPass,
+            endMarker: options.endMarker,
+            assistantText,
+        });
